# Replace lifeos.ledion.io with the real hostname before deploy.
# Caddy will automatically issue a TLS cert via Let's Encrypt on first request.

lifeos.ledion.io {
	encode gzip

	# Health endpoint exposed by mcp service (Phase 8). Open to the world so
	# uptime checks don't need the bearer token.
	handle /health {
		reverse_proxy mcp:8080
	}

	# Lifelog iOS app surface. Mounted on the same FastAPI app as the MCP
	# server but uses bearer-token auth (Authorization: Bearer
	# <LIFELOG_API_TOKEN>) per route, not path-secret. Pass through verbatim.
	handle /lifelog/* {
		reverse_proxy mcp:8080
	}

	# Body-image rating surface. Same bearer auth as /lifelog/*; the daily
	# iOS Shortcut POSTs a headshot to /body-image/upload. Dashboard lives
	# at /body-image/dashboard?token=<LIFELOG_API_TOKEN>.
	handle /body-image/* {
		reverse_proxy mcp:8080
	}

	# Everything else is the MCP HTTP server. Auth is enforced inside the app
	# via the Authorization: Bearer <MCP_API_KEY> header.
	handle {
		reverse_proxy mcp:8080
	}

	# 10 req/sec per remote IP. Cheap defense against accidents and casual
	# scanning. Tune up if Claude.ai's connector ever bursts harder.
	# (Requires the rate-limit plugin; comment out if running stock Caddy.)
	# rate_limit {
	#   zone mcp {
	#     key {remote_host}
	#     events 10
	#     window 1s
	#   }
	# }

	log {
		output stdout
		format console
		level INFO
	}
}
