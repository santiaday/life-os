# =============================================================================
# life-os environment template
# Copy to .env and fill in. Never commit .env.
# Generate MCP_API_KEY with: openssl rand -hex 32
# =============================================================================

# ---- Database ---------------------------------------------------------------
# Supabase pooled connection string (transaction mode, port 6543).
SUPABASE_DB_URL=postgresql://postgres.xxxxxxxx:CHANGE_ME@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Direct (session) connection used for migrations / role creation. Port 5432.
SUPABASE_DB_URL_DIRECT=postgresql://postgres.xxxxxxxx:CHANGE_ME@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# Password assigned to the lifeos_mcp read-only role created in 0006_views.sql.
MCP_DB_PASSWORD=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND

# Read-only DSN used by the MCP server's ask_sql tool (and the generic db_* /
# execute_sql write tools' introspection runs on the admin URL above).
# IMPORTANT: when going through the Supabase pooler (port 6543), the username
# MUST carry the project ref like the admin URLs do — `lifeos_mcp.<PROJECT_REF>`,
# NOT a bare `lifeos_mcp`. A bare role name makes the pooler reject the
# connection ("tenant/user lifeos_mcp not found") and ask_sql fails with
# pool-timeout. Use the same <PROJECT_REF> as the postgres.<ref> in the URLs above.
LIFEOS_READER_DB_URL=postgresql://lifeos_mcp.xxxxxxxx:CHANGE_ME@aws-0-us-east-1.pooler.supabase.com:6543/postgres

LOCAL_TZ=America/New_York

# ---- Whoop ------------------------------------------------------------------
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=https://lifeos.example.com/oauth/whoop/callback
WHOOP_WEBHOOK_SECRET=

# ---- Whoop private journal API (iPhone-bridge auth) ------------------------
# The iPhone Shortcut runs REFRESH_TOKEN_AUTH against Whoop and POSTs fresh
# tokens to /lifelog/whoop/refresh-callback on this server. The server never
# touches Whoop's auth-service or AWS Cognito — Cloudflare blocks the former
# and we don't have a SECRET_HASH for the latter.
# See ingest_whoop_journal/RUNBOOK.md for the full bootstrap walkthrough.
#
# Generate once:  python -c "import secrets; print(secrets.token_urlsafe(32))"
# Paste the same value into the iOS Shortcut's request headers.
WHOOP_REFRESH_WEBHOOK_SECRET=
# Legacy fields (unused). Kept so old .env files don't trip pydantic-settings.
WHOOP_PRIVATE_EMAIL=
WHOOP_PRIVATE_PASSWORD=
WHOOP_COGNITO_CLIENT_ID=37365lrcda1js3fapqfe2n40eh

# ---- Google Calendar --------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://lifeos.example.com/oauth/google/callback
GOOGLE_CALENDAR_IDS=primary
INTERNAL_EMAIL_DOMAINS=doorloop.com

# ---- Cronometer -------------------------------------------------------------
CRONOMETER_USERNAME=
CRONOMETER_PASSWORD=

# ---- Cal AI (Firebase-backed nutrition; see ingest_calai/RUNBOOK.md) --------
# Firebase Web API key for project calai-app — the ?key= param on the Cal AI
# login (identitytoolkit/securetoken) request. Needed to refresh the ID token.
CALAI_FIREBASE_API_KEY=
# Firestore collection holding the food diary + its date field — confirm from a
# captured diary read. The refresh token is stored via `python -m ingest_calai login`.
CALAI_DIARY_COLLECTION=
CALAI_DIARY_DATE_FIELD=createdAt

# ---- PushPress (gym programmed-workouts) -----------------------------------
# Used as a fallback when the cached refresh token has expired (60-day TTL).
# After bootstrap, tokens live in oauth_tokens(service='pushpress') and rotate
# on every refresh — credentials only get used when refresh fails outright.
# Bootstrap once: python -m ingest_pushpress login
PUSHPRESS_USERNAME=
PUSHPRESS_PASSWORD=

# ---- Coach (WOD parser + load recommender) --------------------------------
# Sonnet 4.5 parses freeform PushPress descriptions into structured
# movements; Haiku does the cheap movement-name fuzzy match.
# Anthropic API key from console.anthropic.com.
ANTHROPIC_API_KEY=
# COACH_HEVY_FOLDER_ID=12345   # optional Hevy folder to drop routines into

# ---- Body-image rating pipeline --------------------------------------------
# Daily headshot from an iOS Shortcut → Claude vision + GPT-4o vision +
# MediaPipe geometry sidecar. Reuses LIFELOG_API_TOKEN for the iOS bearer.
# See body_image/RUNBOOK.md.
OPENAI_API_KEY=
# Supabase project URL + SERVICE ROLE key (not the anon key). Dashboard
# → Settings → API. Required only for body_image storage uploads.
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=
# Storage bucket name; create it manually in Supabase dashboard with
# "public: off" before first upload.
BODY_IMAGE_BUCKET=body-image

# ---- Copilot Money ----------------------------------------------------------
# No env vars needed. Auth uses a Firebase refresh token captured from your
# browser; persisted in the oauth_tokens DB table via:
#   python -m ingest_copilot set-refresh-token --token AMf-...
# See ingest_copilot/auth.py for how to grab the token from DevTools.

# ---- MCP --------------------------------------------------------------------
MCP_API_KEY=
MCP_PUBLIC_BASE_URL=https://lifeos.example.com
MCP_BIND_HOST=0.0.0.0
MCP_BIND_PORT=8080

# ---- Logging / observability ------------------------------------------------
LOG_LEVEL=INFO
SENTRY_DSN=

# OTLP tracing (optional; works with Langfuse Cloud free tier or Grafana
# Cloud free tier). Leave empty to disable; Postgres-side mcp_tool_log still
# captures every call regardless. For Langfuse:
#   LIFEOS_OTLP_ENDPOINT=https://cloud.langfuse.com/api/public/otel/v1/traces
#   LIFEOS_OTLP_HEADERS=Authorization=Basic <base64(public_key:secret_key)>
LIFEOS_OTLP_ENDPOINT=
LIFEOS_OTLP_HEADERS=
LIFEOS_SERVICE_NAME=life-os-mcp

# ---- Connection pool tuning -------------------------------------------------
# Defaults chosen for personal-scale (single user, occasional concurrent
# tool calls). Bump LIFEOS_READER_POOL_MAX if ask_sql ever times out due to
# pool exhaustion (e.g. Claude firing parallel correlate_metrics calls).
LIFEOS_POOL_MIN=2
LIFEOS_POOL_MAX=12
LIFEOS_READER_POOL_MIN=1
LIFEOS_READER_POOL_MAX=8
LIFEOS_READER_POOL_TIMEOUT=10

# ---- Alerting (Phase 8) -----------------------------------------------------
# Pick one or both. If neither is set, stale-source alerts only land in
# `docker compose logs scheduler` at WARN level.
PUSHOVER_USER_KEY=
PUSHOVER_API_TOKEN=
SLACK_ALERT_WEBHOOK_URL=

# ---- Backups (Phase 8) ------------------------------------------------------
# scripts/backup.sh uses these to push pg_dump.sql.gz to a DigitalOcean
# Spaces (or any s3-compatible) bucket nightly via host cron.
BACKUP_S3_BUCKET=
BACKUP_S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
BACKUP_S3_ACCESS_KEY_ID=
BACKUP_S3_SECRET_ACCESS_KEY=
BACKUP_RETENTION_DAYS=30

# ---- Couples-split workflow -------------------------------------------------
# Tag names used by set_couple_tag / list_pending_couple_review /
# compute_couple_balances. Auto-created in Copilot on first use.
COUPLE_TAG_ME=me
COUPLE_TAG_PARTNER=paulina
COUPLE_TAG_JOINT=joint
# Joint expense split (must sum to 1.0).
COUPLE_SPLIT_ME=0.5
COUPLE_SPLIT_PARTNER=0.5
# Comma-separated dim_account.account_id values mapping each card/account to
# its primary owner. compute_couple_balances uses this to figure out who paid
# for each transaction. Get the IDs via the list_account_owners MCP tool or
#   psql> SELECT account_id, name FROM dim_account;
COUPLE_ACCOUNTS_ME=
COUPLE_ACCOUNTS_PARTNER=
COUPLE_ACCOUNTS_JOINT=
